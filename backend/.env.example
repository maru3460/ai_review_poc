GITHUB_APP_ID=123456
GITHUB_TOKEN=ghp_replace_with_token
GITHUB_WEBHOOK_SECRET=replace-with-long-secret
GITHUB_BOT_LOGIN=ai-review-bot
GITHUB_API_BASE_URL=https://api.github.com

# ポート設定: ローカル開発では BACKEND_PORT を使う。
# Railway では PORT が自動注入されるため設定不要。
BACKEND_PORT=3001

# Redis接続URL（オプション）: Railway では ${{Redis.REDIS_URL}} を設定する。
# 未設定の場合はインメモリキューで動作する。
# REDIS_URL=redis://localhost:6379
